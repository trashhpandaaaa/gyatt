# Gyatt ignore file
# Similar to .gitignore

# Gyatt directory
.gyatt/

# Compiled files
*.o
*.a
*.so
*.exe
*.dll
*.dylib
*.out

# Build directories
build/
bin/
lib/

# Logs and databases
*.log
*.sql
*.sqlite

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
